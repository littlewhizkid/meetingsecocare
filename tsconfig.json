{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "vite.config.ts", "src/App.tsx", "src/main.tsx", "src/firebase.ts", "src/constants.legacy.ts", "src/types.legacy.ts", "src/vite-env.d.ts", "src/components/MyBookingsPanel.legacy.tsx", "src/components/RoomSelector.legacy.tsx", "src/components/ToastStack.legacy.tsx", "src/utils/bookings.legacy.ts", "src/utils/date.legacy.ts", "src/utils/storage.legacy.ts"]
}
